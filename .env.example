# Copy to .env.local and fill in. Never commit .env.local.

# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, or any Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional: Cloudflare Turnstile for bot protection (get keys at dashboard.cloudflare.com)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
